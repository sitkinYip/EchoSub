{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/v2/crates/tauri-utils/schema.json",
  "productName": "EchoSub",
  "version": "0.1.0",
  "identifier": "com.subtitle.translator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EchoSub - AI 字幕翻译",
        "width": 1100,
        "height": 750,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg"]
  }
}
