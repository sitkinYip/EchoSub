# ── Dependencies ──────────────────────────────────
node_modules/

# ── Build outputs ────────────────────────────────
/dist/
/src-tauri/target/

# ── Tauri generated files (regenerated on build) ─
/src-tauri/gen/

# ── Sidecar binaries (too large, download separately) ─
/src-tauri/binaries/ffmpeg-*
/src-tauri/binaries/llama-server-*
/src-tauri/binaries/*.dylib
/src-tauri/binaries/*.dll
!/src-tauri/binaries/.gitkeep

# ── macOS ────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── IDE / Editor ─────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Environment / Secrets ────────────────────────
.env
.env.local
.env.*.local

# ── OS junk ──────────────────────────────────────
Thumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────
*.log
npm-debug.log*

